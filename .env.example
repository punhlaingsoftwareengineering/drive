DATABASE_URL=""

# Password with @ must be encoded as %40 in the URL. For LAN Postgres without TLS add ?sslmode=disable
# DATABASE_URL=postgresql://postgres:pass%40word@10.100.100.67:5432/db_drive?sslmode=disable

# Shared Better Auth DB (employee portal `user` / `session` tables). Required for SSO.
# AUTH_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/employee_portal

# Employee portal origin for SSO redirects (must match portal ORIGIN)
# Local: http://portal.local.test
# Production: https://phh.com
PORTAL_ORIGIN=""

# Cross-subdomain SSO cookie
# Local: .local.test
# Production: .phh.com
# AUTH_COOKIE_DOMAIN=".local.test"

# Session: 7d refresh window, 30m access revalidation (must match portal)
# AUTH_SESSION_EXPIRES_IN=7d
# AUTH_SESSION_UPDATE_AGE=30m
# AUTH_SESSION_COOKIE_CACHE_MAX_AGE=30m

# Public site name shown in navbar, page titles, and UI copy
PUBLIC_APP_NAME=ZNL-DRIVE

# Drive public URL (must match browser address exactly)
# Local: http://drive.local.test
# Production: https://office.drive.phh.com
ORIGIN=""

# adapter-node listen port (default 1025 in Docker/Fly)
PORT=1025

# Max per-request body size (must be >= upload chunk size, default 8 MiB chunks)
BODY_SIZE_LIMIT=8M

# Max single file size in bytes (0 = unlimited; limited by disk / provider)
MAX_UPLOAD_BYTES=0

# Leave empty for OS default: ~/Documents/drive (Windows: %USERPROFILE%\Documents\drive)
# Docker: use /data/znl-drive inside the container (set in docker-compose.yml)
LOCAL_DRIVE_DATA_DIR=

# Docker Compose bind mount (host side). Works on any OS:
#   ./data/drive
#   ${USERPROFILE}/Documents/drive   (Windows)
#   ${HOME}/Documents/drive          (macOS / Linux)
LOCAL_DRIVE_HOST_PATH=./data/drive

# Must match employee portal exactly (shared across both apps)
BETTER_AUTH_SECRET=""

GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

TIGRIS_STORAGE_ACCESS_KEY_ID=
TIGRIS_STORAGE_SECRET_ACCESS_KEY=
TIGRIS_STORAGE_BUCKET=
TIGRIS_STORAGE_ENDPOINT=https://t3.storage.dev
TIGRIS_STORAGE_IAM_ENDPOINT=https://iam.storage.dev
TIGRIS_STORAGE_REGION=auto

FILE_ENCRYPTION_KEY=""
# Alias: DRIVE_ENCRYPTION_KEY (either name works)

GMAIL_USER=""
GMAIL_APP_PASSWORD=""

# Generic SMTP (preferred over Gmail fallback)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Scheduled trash purge (POST /api/cron/purge-trash with Bearer token)
CRON_SECRET=

# Developer API key quotas (per user). 0 or unset = unlimited. Browser sessions are not capped.
# DEVELOPER_API_MAX_TEAMS=10
# DEVELOPER_API_MAX_FOLDERS=500
# DEVELOPER_API_MAX_FILES=5000
# DEVELOPER_API_MAX_API_KEYS=5

# Behind a reverse proxy / Fly.io TLS edge (omit for direct HTTP access)
# PROTOCOL_HEADER=x-forwarded-proto
# HOST_HEADER=x-forwarded-host
